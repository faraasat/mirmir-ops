{
  "name": "extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && tsc && vite build",
    "build:chrome": "node scripts/generate-icons.mjs && cross-env BROWSER=chrome vite build",
    "build:firefox": "node scripts/generate-icons.mjs && cross-env BROWSER=firefox vite build",
    "build:all": "node scripts/generate-icons.mjs && npm run build:chrome && npm run build:firefox",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.0",
    "@xenova/transformers": "^2.17.0",
    "compromise": "^14.12.0",
    "compromise-dates": "^3.5.0",
    "compromise-numbers": "^1.4.0",
    "date-fns": "^3.3.0",
    "dexie": "^4.0.0",
    "dexie-react-hooks": "^1.1.7",
    "multi-llm-ts": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^9.0.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@types/webextension-polyfill": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
